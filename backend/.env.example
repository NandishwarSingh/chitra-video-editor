# Bind address for the HTTP server.
CHITRA_BIND_ADDR=127.0.0.1:8787

# Comma-separated origins allowed via CORS (Vite dev defaults to localhost:5173/5183).
CHITRA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5183

# Postgres connection string for project sync + asset metadata.
# Create a local instance with:  docker run --rm -p 5432:5432 -e POSTGRES_PASSWORD=chitra postgres:16
DATABASE_URL=postgres://postgres:chitra@localhost:5432/chitra

# Object storage (S3 or S3-compatible: MinIO, Cloudflare R2, etc).
CHITRA_S3_BUCKET=chitra-assets
CHITRA_S3_REGION=us-east-1
CHITRA_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LLM proxy. Used by the AI Chat panel.
# Supports OpenRouter (recommended) or any OpenAI-compatible /v1/chat/completions endpoint.
CHITRA_LLM_PROVIDER=openrouter
CHITRA_LLM_BASE_URL=https://openrouter.ai/api/v1
CHITRA_LLM_API_KEY=
CHITRA_LLM_MODEL=anthropic/claude-sonnet-4-6

# Path to the ffmpeg binary used by the transcode worker.
CHITRA_FFMPEG_PATH=ffmpeg

# Speech-to-text. Default provider is local whisper.cpp — no API key, no
# network call. To enable:
#   macOS:  brew install whisper-cpp
#           bash ./models/download-ggml-model.sh small   (in whisper.cpp repo)
#   Linux:  build whisper.cpp from source, run download-ggml-model.sh small
# Set CHITRA_WHISPER_MODEL to the absolute path of the resulting ggml-small.bin.
CHITRA_STT_PROVIDER=whisper_cpp
CHITRA_WHISPER_BIN=whisper-cli
CHITRA_WHISPER_MODEL=
# Silero VAD model (~1.5 MB). Strongly recommended — it pre-segments audio
# into voiced regions before whisper decodes, eliminating the standard
# "Thanks for watching" hallucinations in silent sections. Download:
#   curl -L https://huggingface.co/ggml-org/whisper-vad/resolve/main/ggml-silero-v5.1.2.bin \
#     -o /path/to/models/ggml-silero-v5.1.2.bin
# Empty value disables VAD.
CHITRA_WHISPER_VAD_MODEL=
CHITRA_WHISPER_THREADS=4

# Alternative provider: Groq cloud Whisper (uncomment + flip provider).
# CHITRA_STT_PROVIDER=groq
# CHITRA_STT_API_KEY=
# CHITRA_STT_MODEL=whisper-large-v3-turbo
# CHITRA_STT_BASE_URL=https://api.groq.com/openai/v1

# Object segmentation / rotoscoping (EfficientTAM, Apache-2.0). Set up with:
#   ./scripts/install-sam2.sh
# It prints the four values below. Empty = /api/segment returns 503.
CHITRA_SAM2_PYTHON=
CHITRA_SAM2_RUNNER=
CHITRA_SAM2_REPO=
CHITRA_SAM2_MODEL=efficienttam_s_512x512

# Beat detection. Default is local madmom (peak accuracy; gives downbeats).
# Install:
#   python3 -m pip install --user 'madmom @ git+https://github.com/CPJKU/madmom.git@main' numpy scipy cython
# Fallback (beats only, easier install):
#   brew install aubio       then set CHITRA_BEAT_PROVIDER=aubio
CHITRA_BEAT_PROVIDER=madmom
CHITRA_BEAT_PYTHON=python3
CHITRA_BEAT_AUBIO_BIN=aubio

# tracing-subscriber filter (RUST_LOG-compatible).
RUST_LOG=info,api=debug,chitra_chat=debug,tower_http=info
